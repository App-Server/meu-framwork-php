{
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "require": {
        "vlucas/phpdotenv": "^5.6"
    },
    "config": {
        "platform": {
            "php": "8.2"
        }
    },
    "scripts": {
        "dev": "php -S localhost:3030 -t public",
        "post-install-cmd": [
            "php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    }
}
